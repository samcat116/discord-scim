# --- Discord source ---
# Bot token from https://discord.com/developers/applications
# The bot must have the "Server Members Intent" enabled and be a member of the guild.
DISCORD_BOT_TOKEN=your-bot-token
# The guild (server) whose members you want to provision.
DISCORD_GUILD_ID=000000000000000000
# Provision bot accounts too (default: false).
INCLUDE_BOTS=false

# --- SCIM target app (the service provider you provision INTO) ---
# Base URL of the app's SCIM 2.0 API.
SCIM_BASE_URL=https://your-app.example.com/scim/v2
# Bearer token the app issued for SCIM provisioning.
SCIM_TOKEN=your-scim-token

# --- Mapping / behaviour ---
# Prefix used in SCIM externalId so this tool only ever touches resources it owns.
EXTERNAL_ID_PREFIX=discord
# Discord bot tokens cannot read member emails. If your app requires emails,
# set a domain and addresses are synthesized as <username>@<domain>.
# EMAIL_DOMAIN=discord.example.com
# Mirror Discord roles as SCIM groups (default: true).
MANAGE_GROUPS=true
# Skip the implicit @everyone role (default: true).
EXCLUDE_EVERYONE_ROLE=true
# Skip integration/bot-managed roles (default: true).
EXCLUDE_MANAGED_ROLES=true
# What to do when a member leaves the guild: deactivate | delete (default: deactivate).
DEPROVISION_ACTION=deactivate

# --- HTTP ---
REQUEST_TIMEOUT=30
